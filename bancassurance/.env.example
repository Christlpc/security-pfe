# Configuration Environnement NSIA Backend

# Mode de développement
DJANGO_ENV=development  # development | production

# Secret Key Django (générer une nouvelle en production)
SECRET_KEY=your-secret-key-here-change-in-production

# Debug Mode (False en production)
DEBUG=True

# Hosts autorisés
ALLOWED_HOSTS=localhost,127.0.0.1

# Base de données PostgreSQL
DB_NAME=nsia_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# CORS (Frontend URLs autorisées)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# JWT Configuration
JWT_ACCESS_TOKEN_LIFETIME=60  # minutes
JWT_REFRESH_TOKEN_LIFETIME=1440  # minutes (24h)

# Redis Cache (optionnel)
REDIS_URL=redis://localhost:6379/0

# Email Configuration (pour notifications)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-password

# Sentry (monitoring erreurs - optionnel)
SENTRY_DSN=

# Uploads & Médias
MEDIA_ROOT=/var/www/nsia/media
STATIC_ROOT=/var/www/nsia/static
